{
  "name": "idle_rpg",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest --config jest.unit.config.js",
    "test:unit": "jest --config jest.unit.config.js --runInBand",
    "test:all": "jest",
    "test:e2e": "playwright test",
    "simulate": "npx ts-node --project tsconfig.sim.json scripts/simulations/missions/battles.ts",
    "simulate:m1": "npm run simulate -- --mission=1",
    "simulate:m2": "npm run simulate -- --mission=2",
    "simulate:m3": "npm run simulate -- --mission=3"
  },
  "dependencies": {
    "@expo/metro-runtime": "^55.0.6",
    "@lottiefiles/dotlottie-react": "^0.13.5",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.14.0",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/routers": "^7.5.3",
    "expo": "~54.0.33",
    "expo-audio": "~1.1.1",
    "expo-av": "~16.0.8",
    "expo-haptics": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "lottie-react-native": "~7.3.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "^0.5.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-flow": "^7.27.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-native": "^5.4.0",
    "@testing-library/react-native": "^12.1.5",
    "@types/jest": "^29.5.3",
    "@types/react": "~19.1.0",
    "@types/react-test-renderer": "^19.1.0",
    "babel-jest": "^29.6.2",
    "babel-preset-expo": "^54.0.10",
    "jest": "^29.6.0",
    "jest-expo": "~54.0.17",
    "react-test-renderer": "^19.1.0",
    "ts-jest": "^29.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
